---
import { getCollection, render } from 'astro:content';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, year, type, status, tags, images, supplemental, links, featuredIn, collab } = entry.data;
const isDev = status === 'in-development';
const featuredImage = images.length > 0 ? images[0] : null;
const remainingImages = images.length > 1 ? images.slice(1) : [];
const isVideo = (src: string) => src.endsWith('.mp4') || src.endsWith('.webm');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${title} — inceptionalism.xyz`} />
    <title>{title} — inceptionalism.xyz</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Nav />
    <main>
      <div class="work-layout">
        <div class="work-layout-image">
          {featuredImage && (
            isVideo(featuredImage) ? (
              <video autoplay muted loop playsinline style="width:100%;height:auto;display:block;">
                <source src={`/${featuredImage}`} type="video/mp4" />
              </video>
            ) : (
              <img src={`/${featuredImage}`} alt={title} loading="eager" />
            )
          )}
        </div>

        <div class="work-layout-text">
          <header class="work-header">
            <div class="work-meta">
              <span class="tag">{isDev ? 'in development' : type}</span>
              <span class="year muted">{year}</span>
              {collab && <span class="muted">w/ {collab}</span>}
            </div>
            <h1>{title}</h1>
            {featuredIn && <p class="featured muted">{featuredIn}</p>}
            {tags.length > 0 && (
              <div class="tags">
                {tags.map((t) => <span class="tag-pill">{t}</span>)}
              </div>
            )}
          </header>

          <div class="prose">
            <Content />
          </div>

          {links && (
            <div class="work-links">
              {links.foundation && (
                <a href={links.foundation} target="_blank" rel="noopener">Foundation</a>
              )}
              {links.opensea && (
                <a href={links.opensea} target="_blank" rel="noopener">OpenSea</a>
              )}
              {links.twitter && (
                <a href={links.twitter} target="_blank" rel="noopener">Thread</a>
              )}
              {links.transient && (
                <a href={links.transient} target="_blank" rel="noopener">view on Transient Labs →</a>
              )}
            </div>
          )}
        </div>
      </div>

      {remainingImages.length > 0 && (
        <div class="work-images work-images-remaining">
          {remainingImages.map((src) => (
            isVideo(src) ? (
              <video autoplay muted loop playsinline>
                <source src={`/${src}`} type="video/mp4" />
              </video>
            ) : (
              <img src={`/${src}`} alt={title} loading="lazy" />
            )
          ))}
        </div>
      )}

      {supplemental.map((section) => (
        <div class="supplemental-section">
          <h3 class="supplemental-label">{section.label}</h3>
          <div class="work-images">
            {section.images.map((src) => (
              isVideo(src) ? (
                <video autoplay muted loop playsinline>
                  <source src={`/${src}`} type="video/mp4" />
                </video>
              ) : (
                <img src={`/${src}`} alt={`${title} — ${section.label}`} loading="lazy" />
              )
            ))}
          </div>
        </div>
      ))}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1200px;
  }

  /* Hero layout: image left, text right */
  .work-layout {
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  .work-layout-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .work-layout-text .work-header {
    max-width: none;
    margin-bottom: 2rem;
  }

  .work-layout-text .prose {
    max-width: none;
    margin-bottom: 2rem;
  }

  .work-layout-text .work-links {
    max-width: none;
    margin-bottom: 0;
  }

  /* Header internals */
  .work-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .featured {
    margin-top: 0.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag-pill {
    border: 1px solid #ddd;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #666;
  }

  /* Prose */
  .prose {
    line-height: 1.7;
  }

  .prose p + p {
    margin-top: 1rem;
  }

  /* Links */
  .work-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    border-top: 1px solid #e8e8e8;
    padding-top: 1.5rem;
  }

  .work-links a {
    text-decoration: underline;
  }

  /* Remaining masonry grid */
  .work-images-remaining {
    margin-top: 4rem;
  }

  /* Supplemental sections */
  .supplemental-section {
    margin-top: 4rem;
  }

  .supplemental-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
    margin-bottom: 1.25rem;
  }

  /* Masonry image grid */
  .work-images {
    columns: 3;
    column-gap: 1rem;
  }

  .work-images img,
  .work-images video {
    display: block;
    width: 100%;
    height: auto;
    margin-bottom: 1rem;
    break-inside: avoid;
  }

  /* Intermediate breakpoint — still side by side, tighter gap */
  @media (max-width: 900px) and (min-width: 769px) {
    .work-layout {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .work-images {
      columns: 2;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .work-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .work-layout-image img {
      margin-bottom: 2rem;
    }

    .work-images {
      columns: 1;
    }
  }
</style>
